{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/cron-scan.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/api/cron-scan",
      "dest": "api/cron-scan.js"
    },
    {
      "src": "^/api(.*)$",
      "dest": "api/index.js"
    },
    {
      "src": "^/(?!api)",
      "dest": "public/index.html"
    }
  ],
  "env": {
    "DATABASE_URL": "@DATABASE_URL",
    "OPENROUTER_API_KEY": "@OPENROUTER_API_KEY",
    "RSS_SOURCES": "@RSS_SOURCES",
    "SCAN_INTERVAL_SECONDS": "@SCAN_INTERVAL_SECONDS"
  },
  "crons": [
    {
      "path": "/api/cron-scan",
      "schedule": "0 0 * * *"
    }
  ]
}
