{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/cron-scan.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/api/cron-scan",
      "dest": "api/cron-scan.js"
    },
    {
      "src": "^/api(.*)$",
      "dest": "api/index.js"
    },
    {
      "src": "^/(.*)$",
      "dest": "public/index.html"
    }
  ],

  "crons": [
    {
      "path": "/api/cron-scan",
      "schedule": "0 0 * * *"
    }
  ]
}
