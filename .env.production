# Vercel 生产环境配置示例
# 请在 Vercel Dashboard 的环境变量中设置真实值

# 数据库连接 (推荐使用 PostgreSQL for 生产环境)
# DATABASE_URL="postgresql://user:password@host:5432/dbname"
# 或使用 SQLite (有持久化限制)
DATABASE_URL="file:./prisma/prod.db"

# OpenRouter API 密钥
OPENROUTER_API_KEY="sk-or-your-production-key"

# RSS 源配置 (JSON 格式)
RSS_SOURCES='[
  {
    "name": "HackerNews",
    "url": "https://news.ycombinator.com/rss",
    "headers": {}
  },
  {
    "name": "ProductHunt",
    "url": "https://www.producthunt.com/feed",
    "headers": {}
  }
]'

# 扫描间隔 (秒)
SCAN_INTERVAL_SECONDS=3600

# 服务器端口 (Vercel 自动设置)
PORT=3000

# 日志级别
LOG_LEVEL="info"
